# PromptShield - Environment Variables
# Copy this file to .env.local and fill in your credentials

# === Core ===
# Public service name shown in the UI
NEXT_PUBLIC_SERVICE_NAME=PromptShield
# Short tagline shown on the landing page
NEXT_PUBLIC_SERVICE_TAGLINE=Protect your AI agents from prompt injection attacks

# === Database (Supabase + Prisma, required) ===
# Supabase pooled connection string. Use the pooler URL for serverless deploys.
DATABASE_URL=
# Supabase direct connection string. Prisma uses this for direct schema operations.
DIRECT_URL=
# Optional Supabase API values for future product surfaces; not used by /api/scan.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Auth (Clerk, required) ===
# Clerk publishable key (pk_test_... or pk_live_...)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clerk secret key (sk_test_... or sk_live_...)
CLERK_SECRET_KEY=
# Sign-in route
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# Sign-up route
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Redirect after sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# Redirect after sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# === MCP (Model Context Protocol, optional) ===
# Secret for verifying inbound MCP requests (generate with: openssl rand -hex 32)
MCP_API_SECRET=
